# App Configuration
PORT=8000
DATABASE_URL=sqlite:///./ticket_routing.db

# Hugging Face Access Token & Model Configuration
# Generate one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_access_token_here

# Hugging Face Model ID. Can be a Conversational LLM (e.g. meta-llama/Llama-3.2-3B-Instruct)
# or a Zero-Shot Classifier (e.g. facebook/bart-large-mnli)
HF_MODEL=meta-llama/Llama-3.2-3B-Instruct
